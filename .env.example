CLIENT_MODE=development

GOOGLE_CLIENT_ID=<Google client Id extracted from google console>

# API Service URLs - Configure for your environment
# For development: use localhost or local IP
# For production: use your deployed backend domain
NEXT_PUBLIC_AUTH_SERVICE=https://expensetrackerapi.duckdns.org/api/v1/auth
NEXT_PUBLIC_ACCOUNT_SERVICE=https://expensetrackerapi.duckdns.org/api/v1/account
NEXT_PUBLIC_USER_SERVICE=https://expensetrackerapi.duckdns.org/api/v1/user
NEXT_PUBLIC_TRANSACTION_SERVICE=https://expensetrackerapi.duckdns.org/api/v1/transaction

# PWA Configuration
NEXT_PUBLIC_APP_NAME=Expense Tracker
NEXT_PUBLIC_APP_DESCRIPTION=Smart Finance Management PWA
# Push notifications / VAPID (placeholders - keep private keys server-side)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=REPLACE_WITH_BASE64_URLSAFE_PUBLIC_KEY
VAPID_PRIVATE_KEY=REPLACE_WITH_BASE64_URLSAFE_PRIVATE_KEY
VAPID_CONTACT=mailto:security@example.com
PUSH_NOTIFICATIONS_ENABLED=true
